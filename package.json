{
  "name": "my-ollama-cli",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.tsx",
    "rebuild": "npm run build && npm start",
    "auto": "node enable-auto-tools.js && npm run rebuild",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "execa": "^8.0.1",
    "ink": "^4.4.1",
    "ink-text-input": "^5.0.0",
    "nanoid": "^5.0.4",
    "react": "^18.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.39",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
