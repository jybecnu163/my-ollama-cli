{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["jest", "node"]     // 添加这一行
  },
  "include": ["src/**/*", "tests/**/*", "test/unit/test-ollama.ts"],   // 包含测试目录
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  }
}